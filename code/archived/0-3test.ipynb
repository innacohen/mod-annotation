       "      <td>b45c13164f1eeaf4ba61ee8522304f7382fa0541831b1ac9559d69f636ed8f20</td>\n",
       "      <td>1</td>\n",
       "      <td>https://modeldb.science/223649?tab=2&amp;file=AlturkiEtAl2016/1_Hemond/Segregated/kaprox.mod</td>\n",
